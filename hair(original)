import random
class Hair:
    def __init__(self, colour, length):
        self.colour = colour
        self.length = length

    def describe(self):
        print(f"So your hair is {self.colour} and about {self.length} cm long")

    def dye(self, new_colour):
        self.colour = new_colour
        
        print(random.choice(choices))
        print(f"Your hair is now {self.colour}.")
        print(random.choice(reactions))
        
choices = ["Horrible choice... ","Shitty taste... ","Mhm not bad... ","Perfect."]
reactions = ["But still ugly asf.","And nicely done now."]

colour = input("Enter the colour of your hair : ")
length = input("How long is your hair? : ")

my_hair = Hair(colour, length)

my_hair.describe()

new_colour = input("Pick a new colour for your hair : ")
my_hair.dye(new_colour)

